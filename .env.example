# LLM Gateway Configuration
# Copy to .env and fill in your values

# Gateway URL (omit for direct Anthropic API)
export LLM_BASE_URL="https://your-gateway.example.com/v1"

# API key for the gateway (falls back to ANTHROPIC_API_KEY if unset)
export LLM_API_KEY="your-api-key"

# Model identifier (e.g. @bedrock/claude-opus-4-6, @provider/model-name)
export LLM_MODEL="claude-sonnet-4-20250514"
